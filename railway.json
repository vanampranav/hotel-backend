{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "healthcheckDisabled": true,
    "numReplicas": 1,
    "startCommand": "sh -c 'echo \"Starting application...\" && /app/startup.sh'",
    "ports": [
      {
        "containerPort": 8080,
        "protocol": "tcp",
        "published": true
      }
    ]
  }
} 